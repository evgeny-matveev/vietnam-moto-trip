{
  "name": "vietnam-quiet-roads",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
    "test:unit": "vitest",
    "test": "pnpm test:unit --run",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "routes:refresh": "node scripts/refresh-routes.mjs",
    "verify": "pnpm format:check && pnpm lint && pnpm check && pnpm test && pnpm build"
  },
  "dependencies": {
    "maplibre-gl": "^5.24.0",
    "marked": "^18.0.6"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@internationalized/date": "^3.12.2",
    "@lucide/svelte": "^1.24.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.69.3",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@vitest/browser-playwright": "^4.1.8",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "playwright": "^1.60.0",
    "shadcn-svelte": "^1.4.2",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vitest-browser-svelte": "^2.1.1"
  },
  "engines": {
    "node": "24.x",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.28.0"
}
